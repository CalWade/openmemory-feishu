{
  "schema": "kairos.openclaw.setup.v2",
  "name": "Kairos",
  "packageName": "memoryops",
  "repository": "https://github.com/CalWade/Kairos",
  "summary": "Feishu collaboration memory engine using lark-cli Runtime, Dashboard visualization, and OpenClaw as Agent host.",
  "requirements": {
    "node": ">=22",
    "globalTools": [
      {
        "name": "lark-cli",
        "check": "lark-cli --version",
        "install": "npm install -g @larksuite/cli"
      }
    ]
  },
  "install": {
    "fromGitHubLink": [
      "git clone https://github.com/CalWade/Kairos.git kairos",
      "cd kairos",
      "npm install",
      "npm run build"
    ]
  },
  "interactiveSteps": [
    {
      "id": "lark_cli_auth",
      "title": "Authorize lark-cli user identity",
      "command": "lark-cli auth login --recommend --profile kairos-alt",
      "userAction": "Follow the official lark-cli auth page. Keep the command running until authorization succeeds. Do not repeatedly run config init --new."
    },
    {
      "id": "runtime_setup",
      "title": "Configure monitored Feishu group",
      "command": "npm run setup:lark-runtime -- --profile kairos-alt --chat-id <oc_xxx> --feishu-webhook <webhook> --test-read --test-webhook",
      "userAction": "Provide target chat_id and the custom bot webhook from the same Feishu group."
    }
  ],
  "postInstallChecks": [
    "npm run dashboard:static",
    "npm run dev -- eval --core",
    "KAIROS_CHAT_ID=<oc_xxx> KAIROS_LARK_PROFILE=kairos-alt npm run lark-runtime:once"
  ],
  "runtime": {
    "dashboard": "npm run dashboard",
    "larkRuntime": "npm run lark-runtime",
    "dryRun": "npm run lark-runtime:once"
  },
  "safeDefaults": {
    "store": "jsonl",
    "dataIngress": "lark-cli runtime",
    "dashboard": "read-only",
    "requiresExplicitWebhookEnv": true
  },
  "docs": [
    "README.md",
    "QUICKSTART.md",
    "USAGE.md",
    "INSTALL.md",
    "OPENCLAW.md",
    "docs/lark-cli-runbook.md",
    "docs/demo-script.md",
    "docs/benchmark-report.md"
  ]
}
