{
  "name": "memoryops",
  "version": "0.1.0",
  "description": "Kairos: Enterprise long-term collaborative memory engine for Feishu and OpenClaw",
  "type": "module",
  "bin": {
    "memoryops": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "test": "vitest",
    "eval:smoke": "tsx src/cli.ts eval --smoke",
    "demo:e2e": "bash scripts/demo-e2e.sh",
    "demo:feishu-workflow": "bash scripts/demo-feishu-workflow.sh",
    "prepack": "npm run build",
    "demo:lark-cli-chat": "bash scripts/demo-lark-cli-chat.sh",
    "eval:core": "tsx src/cli.ts eval --core",
    "dashboard": "tsx src/cli.ts eval --core >/dev/null && tsx src/cli.ts dashboard --serve --port 8787",
    "dashboard:static": "tsx src/cli.ts eval --core >/dev/null && tsx src/cli.ts dashboard --output runs/kairos-engine-dashboard.html",
    "lark-runtime": "tsx src/cli.ts lark-cli runtime --chat-id \"$KAIROS_CHAT_ID\" --profile \"${KAIROS_LARK_PROFILE:-kairos-alt}\" --llm-thread-link --fallback --send-feishu-webhook",
    "lark-runtime:once": "tsx src/cli.ts lark-cli runtime --chat-id \"$KAIROS_CHAT_ID\" --profile \"${KAIROS_LARK_PROFILE:-kairos-alt}\" --llm-thread-link --fallback --once",
    "setup:lark-runtime": "tsx src/cli.ts lark-cli runtime-setup --write-env",
    "setup:lark-runtime:check": "tsx src/cli.ts lark-cli runtime-setup --test-read"
  },
  "keywords": [
    "memory",
    "agent",
    "feishu",
    "openclaw",
    "lark"
  ],
  "author": "Calvin Wei <CalvinvWei@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.9.0",
    "commander": "latest",
    "zod": "latest"
  },
  "openclaw": {
    "hooks": [
      "hooks/kairos-feishu-ingress"
    ],
    "setup": "openclaw.setup.json",
    "docs": [
      "OPENCLAW.md",
      "INSTALL.md",
      "docs/lark-cli-runbook.md",
      "docs/openclaw-hook-install.md",
      "docs/openclaw-agent-checklist.md"
    ]
  },
  "files": [
    "dist",
    "hooks",
    "README.md",
    "QUICKSTART.md",
    "LICENSE",
    "package.json",
    "INSTALL.md",
    "docs/openclaw-hook-install.md",
    "OPENCLAW.md",
    "openclaw.setup.json",
    "docs/lark-cli-runbook.md",
    "docs/openclaw-agent-checklist.md"
  ]
}
