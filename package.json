{
  "name": "memoryops",
  "version": "0.1.0",
  "description": "Kairos: Enterprise long-term collaborative memory engine for Feishu and OpenClaw",
  "type": "module",
  "bin": {
    "memoryops": "./dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "test": "vitest",
    "eval:smoke": "tsx src/cli.ts eval --smoke",
    "demo:e2e": "bash scripts/demo-e2e.sh",
    "demo:feishu-workflow": "bash scripts/demo-feishu-workflow.sh"
  },
  "keywords": [
    "memory",
    "agent",
    "feishu",
    "openclaw",
    "lark"
  ],
  "author": "Calvin Wei <CalvinvWei@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.9.0",
    "commander": "latest",
    "zod": "latest"
  },
  "openclaw": {
    "hooks": {
      "kairos-feishu-ingress": "hooks/kairos-feishu-ingress"
    }
  }
}
